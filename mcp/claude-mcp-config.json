{
  "mcpServers": {
    "simhub-telemetry": {
      "command": "node",
      "args": ["mcp/simhub-telemetry/dist/index.js"],
      "env": {}
    },
    "k10-plugin": {
      "command": "node",
      "args": ["mcp/k10-plugin/dist/index.js"],
      "env": {
        "K10_PLUGIN_ROOT": "simhub-plugin"
      }
    },
    "k10-broadcaster": {
      "command": "node",
      "args": ["mcp/k10-broadcaster/dist/index.js"],
      "env": {
        "K10_BROADCASTER_ROOT": "k10-media-broadcaster/src"
      }
    }
  }
}
